# Plaid API — get credentials at https://dashboard.plaid.com
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_secret
PLAID_ENV=sandbox
# Options: sandbox (test data), development (real banks, 100 items free), production

# Anthropic — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key
